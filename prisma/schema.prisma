generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String    @default("USER")
  googleApiKey  String?   // Per-user Gemini API key (overrides global env)
  allowedChannels String[] @default(["web", "telegram", "messenger"])
  accounts      Account[]
  bots          Bot[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Bot {
  id                   String         @id @default(cuid())
  name                 String
  systemPrompt         String
  primaryColor         String         @default("#3b82f6")
  userId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  telegramBotToken     String?
  onboardingEnabled    Boolean        @default(false)
  onboardingWelcome    String?
  onboardingTopics     Json?

  // Messenger Integration
  messengerPageToken   String?
  messengerPageId      String?
  messengerVerifyToken String?
  messengerAppSecret   String?
  messengerEnabled     Boolean        @default(false)

  // Google Sheets Integration
  googleSheetId        String?
  googleSheetName      String?        @default("Orders")

  // Messenger bot mode: 'ai' uses Gemini, 'rule_based' uses keyword auto-replies
  messengerMode           String         @default("ai")

  // Customizable welcome message sent on GET_STARTED and fallback
  messengerWelcomeMessage String?

  // Customizable contact us message
  messengerContactMessage String?

  // Customizable payment instructions message
  messengerPaymentMessage String?

  user                    User                    @relation(fields: [userId], references: [id])
  conversations           Conversation[]
  documents               Document[]
  onboardingCompletions   OnboardingCompletion[]
  products                Product[]
  deliveryZones           DeliveryZone[]
  orders                  Order[]
  messengerSessions       MessengerSession[]
  telegramMembers         TelegramMember[]
  announcements           Announcement[]
  messengerAutoReplies    MessengerAutoReply[]

  @@map("bot")
}

model Document {
  id        String   @id @default(cuid())
  content   String
  botId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String   @default("Untitled document")
  bot       Bot      @relation(fields: [botId], references: [id])

  @@map("document")
}

model Conversation {
  id        String    @id @default(cuid())
  botId     String
  createdAt DateTime  @default(now())
  bot       Bot       @relation(fields: [botId], references: [id])
  messages  Message[]

  @@map("conversation")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("message")
}

model OnboardingCompletion {
  id               String   @id @default(cuid())
  botId            String
  telegramChatId   String
  telegramUsername String?
  topicId          String
  topicLabel       String
  verifiedCount    Int      @default(0)
  completedAt      DateTime @default(now())
  bot              Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, telegramChatId, topicId])
  @@map("onboarding_completion")
}

// ─── E-Commerce Models ───

model Product {
  id          String   @id @default(cuid())
  botId       String
  name        String
  price       Float    @default(0)
  category    String   @default("General")
  stockCount  Int      @default(0)
  image       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("product")
}

model DeliveryZone {
  id        String   @id @default(cuid())
  botId     String
  township  String
  city      String   @default("")
  fee       Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("delivery_zone")
}

model Order {
  id                String   @id @default(cuid())
  botId             String
  messengerSenderId String?
  customerName      String?
  customerPhone     String?
  customerAddress   String?
  customerTownship  String?
  items             Json     @default("[]")
  subtotal          Float    @default(0)
  deliveryFee       Float    @default(0)
  total             Float    @default(0)
  status            String   @default("pending")
  paymentMethod     String?
  sheetSynced       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("order")
}

model MessengerSession {
  id                String   @id @default(cuid())
  botId             String
  messengerSenderId String
  state             String   @default("browsing")
  cart              Json?
  pendingData       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, messengerSenderId])
  @@map("messenger_session")
}

// ─── Telegram Member Management ───

model TelegramMember {
  id               String   @id @default(cuid())
  botId            String
  telegramChatId   String
  telegramUsername String?
  firstName        String?
  lastName         String?
  memberType       String   @default("new") // "new" or "old"
  joinedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bot              Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, telegramChatId])
  @@map("telegram_member")
}

model Announcement {
  id          String   @id @default(cuid())
  botId       String
  title       String
  content     String
  sentAt      DateTime?
  isSent      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("announcement")
}

// ─── Messenger Rule-Based Auto Replies ───

model MessengerAutoReply {
  id        String   @id @default(cuid())
  botId     String
  keyword   String   // trigger keyword (case-insensitive match)
  reply     String   // reply text to send
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("messenger_auto_reply")
}
